#!/bin/sh
update() {
  MODE="$1"
  if [ -z "$MODE" ]; then
    MODE="$(cat ~/.local/state/tymek-theme/mode || echo 'dark')"
  fi

  if [ "$MODE" = "light" ]; then
    THEME="tokyonight_day"
  else
    THEME="tokyonight_storm"
  fi

  tmux source "$HOME/.local/share/nvim/lazy/tokyonight.nvim/extras/tmux/$THEME.tmux"
  tmux-prefix-highlight
  return
}

update "$1"
